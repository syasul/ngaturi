{
  "name": "website-undangan-online",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter \"*\" dev",
    "build": "bun run --filter \"*\" build",
    "lint": "bun run --filter \"*\" lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,css,json}\" \"packages/**/*.{ts,tsx,js,jsx,css,json}\" \"*.json\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
